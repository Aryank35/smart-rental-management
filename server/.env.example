# ── TenantFlow API environment ──────────────────────────────────────────────
# Copy this file to ".env" and fill in real values.  NEVER commit the real .env.

# MongoDB connection string.
#  • Local install:   mongodb://127.0.0.1:27017/tenantflow
#  • MongoDB Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/tenantflow?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/tenantflow

# Secret used to sign JWTs. Use a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Port the API listens on.
PORT=4000

# Frontend origin allowed by CORS (the Vite dev server).
CLIENT_URL=http://localhost:5173

# Optional: public DNS servers, comma-separated. Set this if you get
# "querySrv ECONNREFUSED" with a mongodb+srv:// Atlas URI (common on some ISPs).
# DNS_SERVERS=8.8.8.8,1.1.1.1
