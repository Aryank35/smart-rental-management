# Frontend environment (Vite). Copy to ".env" to override defaults.

# Base URL for the API.
#  • Local dev:    leave UNSET — Vite proxies "/api" → http://localhost:4000
#                  (see vite.config.ts), so the app works with no .env at all.
#  • Production:   set to your deployed backend, INCLUDING the /api suffix, e.g.
#                  VITE_API_URL=https://tenantflow-api.onrender.com/api
#
# On Vercel, set this as an Environment Variable in the project settings
# (Production + Preview) rather than committing it here.
# VITE_API_URL=https://tenantflow-api.onrender.com/api
